# Production environment variables for CropCloud web app
# Update these with your production API URL after deploying the backend

# API Configuration
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1

# Razorpay Configuration (Production Keys)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_YOUR_PRODUCTION_KEY_ID

# Note: Never commit sensitive production keys to git
# Use Vercel dashboard to set these secrets instead
