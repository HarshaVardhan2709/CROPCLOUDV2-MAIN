{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "ignoreDeprecations": "5.0",
    "types": ["node"],
    "paths": {
      "src/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src",
    "prisma"
  ]
}